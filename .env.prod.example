# Production environment variables
# Copy this file to .env.prod and fill in all values before running:
#   docker compose --env-file .env.prod -f docker-compose.prod.yml up -d

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=flightapp

# Full connection string used by the app (must match the values above)
DATABASE_URL=postgresql://postgres:CHANGE_ME_STRONG_DB_PASSWORD@db:5432/flightapp

# ── App secrets ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
SESSION_SECRET=CHANGE_ME_LONG_RANDOM_STRING
PREVIEW_SECRET=CHANGE_ME_LONG_RANDOM_STRING

# ── Admin panel ──────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
# Generate a bcrypt hash for your password, e.g.:
#   node -e "const b=require('bcryptjs'); b.hash('yourpassword',12).then(console.log)"
ADMIN_PASSWORD_HASH=CHANGE_ME_BCRYPT_HASH

# ── MinIO (S3-compatible storage) ────────────────────────────────────────────
MINIO_ROOT_USER=CHANGE_ME_MINIO_USER
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD

S3_ENDPOINT=http://minio:9000
S3_BUCKET=flight-app-media
# Must match MINIO_ROOT_USER and MINIO_ROOT_PASSWORD above
S3_ACCESS_KEY=CHANGE_ME_MINIO_USER
S3_SECRET_KEY=CHANGE_ME_MINIO_PASSWORD
# Public URL used by browsers to fetch uploaded assets
# Replace with your actual domain, e.g. https://storage.example.com/flight-app-media
S3_PUBLIC_URL=http://localhost:9000/flight-app-media
