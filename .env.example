# Database connection string for local development
# Copy this file to .env and update values if needed
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/flightapp

# Admin panel authentication
# Generate a bcrypt hash for your password, e.g.:
#   node -e "const b=require('bcryptjs'); b.hash('yourpassword',12).then(console.log)"
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=

# Secret used to sign session tokens — use a long random string in production
SESSION_SECRET=change-me-to-a-long-random-string

# Secret used to sign preview tokens — use a long random string in production
PREVIEW_SECRET=change-me-to-a-long-random-string

# S3-compatible object storage (MinIO for local dev, AWS S3 for production)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=flight-app-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_PUBLIC_URL=http://localhost:9000/flight-app-media
